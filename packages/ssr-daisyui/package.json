{
  "name": "ssr-daisyui",
  "author": "Tegonal Cooperative <info@tegonal.com>",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.4",
    "yarn": ">=4.2"
  },
  "homepage": "https://github.com/tegonal/react-router-templates",
  "scripts": {
    "build": "yarn run typecheck && react-router build",
    "dev": "react-router dev",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --fix --cache --cache-location ./node_modules/.cache/eslint .",
    "prettier": "prettier --write --list-different .",
    "pretty": "prettier --write \"app/**/*.{js,json,ts,tsx}\"",
    "start": "react-router-serve build/server/index.js",
    "typecheck": "react-router typegen && tsc --version && tsc --build --noEmit",
    "up": "yarn upgrade-interactive",
    "i18n:extract": "i18next './app/**/*.{js,ts,tsx}' --config i18next-parser.config.mjs && yarn i18n:generate",
    "i18n:generate": "i18next-resources-for-ts toc -i ./app/locales/en/ -o ./app/locales/en.ts && i18next-resources-for-ts toc -i ./app/locales/de/ -o ./app/locales/de.ts",
    "self-update": "yarn set version latest && yarn",
    "check": "yarn lint:fix && yarn prettier && yarn typecheck"
  },
  "dependencies": {
    "@epic-web/client-hints": "^1.3.8",
    "@epic-web/invariant": "^1.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@icons-pack/react-simple-icons": "^13.7.0",
    "@mjackson/form-data-parser": "^0.9.1",
    "@react-router/serve": "^7.9.1",
    "@uidotdev/usehooks": "^2.4.1",
    "axios": "^1.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "es-toolkit": "^1.39.10",
    "i18next": "25.5.2",
    "i18next-browser-languagedetector": "8.2.0",
    "i18next-fetch-backend": "^6.0.0",
    "is-ip": "^5.0.1",
    "isbot": "^5.1.31",
    "lucide-react": "^0.544.0",
    "pretty-cache-header": "^1.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.63.0",
    "react-i18next": "^16.0.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.9.1",
    "remix-hook-form": "^7.1.0",
    "remix-i18next": "^7.4.0",
    "remix-utils": "^9.0.0",
    "tailwind-merge": "^3.3.1",
    "tslog": "^4.9.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@epic-web/config": "^1.21.3",
    "@react-router/dev": "^7.9.1",
    "@svgr/plugin-svgo": "^8.1.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "daisyui": "^5.1.14",
    "eslint": "^9.36.0",
    "eslint-plugin-perfectionist": "^4.15.0",
    "eslint-plugin-react": "^7.37.5",
    "i18next-parser": "^9.3.0",
    "i18next-resources-for-ts": "^1.7.4",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "sharp": "^0.34.4",
    "svgo": "^4.0.0",
    "tailwindcss": "^4.1.13",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.44.1",
    "vite": "^7.1.7",
    "vite-plugin-image-optimizer": "^2.0.2",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "packageManager": "yarn@4.9.2"
}
