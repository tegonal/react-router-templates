{
  "name": "csr-daisyui",
  "author": "Tegonal Cooperative <info@tegonal.com>",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=24.0.0",
    "yarn": ">=4.2"
  },
  "homepage": "https://github.com/tegonal/react-router-templates",
  "scripts": {
    "start": "vite preview --host",
    "test": "echo \"Error: no test specified\" && exit 1",
    "up": "yarn upgrade-interactive",
    "dev": "vite --host",
    "build": "vite build --mode development",
    "build:dev": "vite build --mode development",
    "build:test": "vite build --mode test",
    "build:prod": "vite build --mode prod",
    "i18n:extract": "i18next-cli extract && i18next-cli types",
    "i18n:extract:watch": "i18next-cli extract --watch",
    "i18n:extract:ci": "i18next-cli extract --ci --dry-run --quiet",
    "i18n:types": "i18next-cli types",
    "i18n:lint": "i18next-cli lint",
    "i18n:sync": "node scripts/i18n-sync.mjs",
    "i18n:generate": "i18next-cli types",
    "prettier": "prettier --write --list-different .",
    "pretty": "prettier --write \"{src,public}/**/*.{ts,tsx,scss,json,html}\"",
    "lint": "eslint --no-warn-ignored app/**/*.{js,ts,jsx,tsx,html}",
    "lint:fix": "eslint --no-warn-ignored app/**/*.{js,ts,jsx,tsx,html} --fix",
    "typecheck": "tsc --build --noEmit",
    "check": "yarn lint:fix && yarn prettier && yarn typecheck"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@uidotdev/usehooks": "^2.4.1",
    "date-fns": "^4.4.0",
    "i18next": "26.3.1",
    "i18next-http-backend": "^4.0.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "react-i18next": "^17.0.8",
    "react-router": "^7.17.0",
    "tslog": "^4.10.2"
  },
  "devDependencies": {
    "@react-router/dev": "^7.17.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@tailwindcss/vite": "^4.3.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/eslint-plugin": "^1.6.17",
    "daisyui": "^5.5.23",
    "eslint": "^9.39.4",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "i18next-cli": "^1.64.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.35.1",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vite-plugin-svgr": "^5.2.0"
  },
  "packageManager": "yarn@4.14.1"
}
