{
  "name": "csr-daisyui",
  "author": "Tegonal Cooperative <info@tegonal.com>",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.4",
    "yarn": ">=4.2"
  },
  "homepage": "https://github.com/tegonal/react-router-templates",
  "scripts": {
    "start": "yarn run generate:types && concurrently \"yarn dev\" \"yarn prism\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "up": "yarn upgrade-interactive",
    "dev": "vite --host",
    "build": "vite build --mode development",
    "build:dev": "vite build --mode development",
    "build:test": "vite build --mode test",
    "build:prod": "vite build --mode prod",
    "i18n:extract": "i18next 'app/**/*.{ts,js,tsx,jsx}'",
    "prettier": "prettier --write --list-different .",
    "pretty": "prettier --write \"{src,public}/**/*.{ts,tsx,scss,json,html}\"",
    "lint": "eslint app/**/*.{js,ts,jsx,tsx,html}",
    "lint:fix": "eslint app/**/*.{js,ts,jsx,tsx,html} --fix",
    "typecheck": "tsc --build --noEmit",
    "check": "yarn lint:fix && yarn prettier && yarn typecheck"
  },
  "dependencies": {
    "@epic-web/config": "^1.21.3",
    "@uidotdev/usehooks": "^2.4.1",
    "date-fns": "^4.1.0",
    "i18next": "^25.5.2",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^0.544.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.63.0",
    "react-i18next": "^15.7.3",
    "react-router": "7.9.1",
    "tslog": "^4.9.3"
  },
  "devDependencies": {
    "@epic-web/config": "^1.21.3",
    "@react-router/dev": "^7.9.1",
    "@svgr/plugin-svgo": "^8.1.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "daisyui": "^5.1.14",
    "eslint": "^9.36.0",
    "eslint-plugin-perfectionist": "^4.15.0",
    "eslint-plugin-react": "^7.37.5",
    "i18next-parser": "^9.3.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "sharp": "^0.34.4",
    "svgo": "^4.0.0",
    "tailwindcss": "^4.1.13",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.44.1",
    "vite": "^7.1.7",
    "vite-plugin-image-optimizer": "^2.0.2",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "packageManager": "yarn@4.9.2"
}
